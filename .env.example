# ─────────────────────────────────────────────────────────
# SHYN Legal — environment variables template
# Copy to .env, fill every REQUIRED value, never commit .env
# ─────────────────────────────────────────────────────────

# ── Public URLs ───────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=https://api.shynlegal.co.uk      # REQUIRED in production
NEXT_PUBLIC_APP_BASE_URL=https://www.shynlegal.co.uk      # REQUIRED in production
NEXT_PUBLIC_CAL_BOOKING_URL=https://cal.com/yourname/30min # REQUIRED — your Cal.com link

# ── Node.js API ───────────────────────────────────────────
API_PORT=4000
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/shynlegal  # REQUIRED
POSTGRES_PASSWORD=CHANGE_ME                                            # REQUIRED

# ── Security ──────────────────────────────────────────────
ADMIN_API_KEY=CHANGE_ME_USE_A_LONG_RANDOM_STRING          # REQUIRED

# ── AI (Ollama) ───────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# ── Cal.com ───────────────────────────────────────────────
CALCOM_API_KEY=                                            # optional
CALCOM_BASE_URL=https://api.cal.com/v2

# ── Telegram notifications ────────────────────────────────
TELEGRAM_BOT_TOKEN=                                        # optional
TELEGRAM_CHAT_ID=                                          # optional

# ── Email (SMTP) ──────────────────────────────────────────
NOTIFY_EMAIL=info@shynlegal.co.uk
SMTP_HOST=smtp.20i.com                                     # REQUIRED for emails
SMTP_PORT=587
SMTP_USER=info@shynlegal.co.uk                             # REQUIRED for emails
SMTP_PASS=                                                 # REQUIRED — your 20i mailbox password
SMTP_FROM=info@shynlegal.co.uk
NOTIFY_EMAIL=info@shynlegal.co.uk

# ── Google Reviews ────────────────────────────────────────
GOOGLE_PLACES_API_KEY=                                     # optional
GOOGLE_PLACE_ID=                                           # optional

# ── Facebook Reviews ──────────────────────────────────────
FACEBOOK_PAGE_ID=                                          # optional
FACEBOOK_PAGE_TOKEN=                                       # optional

# ── WordPress (Docker) ────────────────────────────────────
WP_DB_PASSWORD=CHANGE_ME                                   # REQUIRED
WP_DB_ROOT_PASSWORD=CHANGE_ME                              # REQUIRED
WORDPRESS_URL=https://admin.shynlegal.co.uk
